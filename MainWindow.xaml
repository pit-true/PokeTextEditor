<Window x:Class="WpfApplication1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        ResizeMode="CanMinimize"
        xmlns:local="clr-namespace:WpfApplication1"
        Title="PokeTextEditor ver2.3" Height="460" Width="636">
    <Grid Height="429" VerticalAlignment="Bottom">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition Width="43*"/>
            <ColumnDefinition Width="167*"/>
        </Grid.ColumnDefinitions>
        <Label x:Name="label1_Copy1" Content="オフセットの候補" Background="#FFFFFF" RenderTransformOrigin="0.14,0.56" Margin="126,161,275,243" Grid.Column="2"/>
        <Label x:Name="label1_Copy" Content="オフセット" Background="#FFFFFF" RenderTransformOrigin="0.14,0.56" Margin="126,55,305,349" Grid.Column="2"/>
        <Border BorderBrush="Gray" BorderThickness="1" HorizontalAlignment="Left" Margin="241,45,0,0" VerticalAlignment="Top" Height="315" Width="239" Grid.Column="2">
            <TextBox x:Name="textBox2" HorizontalAlignment="Left" TextWrapping="Wrap" Height="280"  Width="220" VerticalAlignment="Top" TextChanged="textBox2_TextChanged" Margin="9,9,0,0"/>
        </Border>
        <Border BorderBrush="Gray" BorderThickness="1" HorizontalAlignment="Left" Margin="10,45,0,0" VerticalAlignment="Top" Height="315" Width="240" Grid.Column="1" Grid.ColumnSpan="2">
            <TextBox x:Name="textBox1" HorizontalAlignment="Left" TextWrapping="Wrap" Height="280" Width="220" VerticalAlignment="Top" AcceptsReturn="True" TextChanged="textBox1_TextChanged" Margin="9,9,0,0" />
        </Border>
        <Button x:Name="button1" Content="セリフ→16進数" FontSize="12" HorizontalAlignment="Left" Margin="131,295,0,0" VerticalAlignment="Top" Width="100" Click="button1_Click" Height="30" FontFamily="MS Gothic" Grid.Column="2"/>
        <Button x:Name="button2" Content="セリフ←16進数" FontSize="12" HorizontalAlignment="Left" Margin="131,330,0,0" VerticalAlignment="Top" Width="100" Click="button2_Click" Height="30" FontFamily="MS Gothic" Grid.Column="2"/>
        <CheckBox x:Name="checkBox1" Content="点字用変換" FontSize="12" HorizontalAlignment="Left" Margin="20,372,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.31,0.667" Checked="checkBox1_Checked" Unchecked="checkBox1_Unchecked" Height="15" Width="80" Grid.Column="1"/>
        <CheckBox x:Name="checkBox2" Content="ウィンドウを常に最前列に表示" FontSize="12" HorizontalAlignment="Left" Margin="20,392,0,0" VerticalAlignment="Top" Checked="checkBox2_Checked" Unchecked="checkBox2_Unchecked" Height="15" Width="162" Grid.Column="1" Grid.ColumnSpan="2"/>
        <TextBox x:Name="NameROM" HorizontalAlignment="Left" Height="19" Margin="44,11,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="76" TextChanged="NameROM_TextChanged" IsReadOnly="True" Grid.Column="2" Text="ROMファイル" FontSize="12"/>
        <Button x:Name="leftSaveROM" Content="ROMに上書き" HorizontalAlignment="Left" Margin="36,336,0,0" VerticalAlignment="Top" Width="75" Click="leftSaveROM_Click" RenderTransformOrigin="0.507,1.15" Height="20" Grid.Column="2"/>
        <Button HorizontalAlignment="Left" VerticalAlignment="Top" Width="75" Grid.Column="2" Height="20" x:Name="RightSaveROM" Content="ROMに上書き" Click="RightSaveROM_Click" RenderTransformOrigin="0.627,0.3" Margin="396,336,0,0"/>
        <TextBox x:Name="offset" HorizontalAlignment="Left" Height="23" Margin="126,78,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="110" TextChanged="offset_TextChanged" RenderTransformOrigin="0.57,0.478" Grid.Column="2"/>
        <Border HorizontalAlignment="Left" Margin="104,30,0,0" VerticalAlignment="Top" Width="50" Height="25" Grid.Column="1" Grid.ColumnSpan="2" >
            <Label x:Name="label1" Content="16進数&#xA;" Background="#FFFFFF" RenderTransformOrigin="0.14,0.56" Margin="287,-1,-287,1"/>
        </Border>
        <Label x:Name="label" Content="セリフ" FontSize="12" HorizontalAlignment="Left" Margin="30,30,0,0" VerticalAlignment="Top" Width="40" Height="25" Background="#FFFFFF" RenderTransformOrigin="0.475,-0.2" Grid.Column="1"/>
        <Button x:Name="OpenROM" FontSize="12" Content="ROMを開く" HorizontalAlignment="Left" VerticalAlignment="Top" Width="75" Click="OpenROM_Click" Height="20" Margin="11,10,0,0" Grid.Column="1"/>
        <Button x:Name="loadMessage" Content="セリフのロード" FontSize="12" HorizontalAlignment="Left" Margin="131,106,0,0" VerticalAlignment="Top" Width="100" Height="30" Click="loadMessage_Click" Grid.Column="2"/>
        <Button x:Name="searchMessage" Content="セリフサーチ" FontSize="12" HorizontalAlignment="Left" Margin="131,35,0,0" VerticalAlignment="Top" Width="100" Click="searchMessage_Click" Grid.Column="2" Height="20"/>
        <ListBox x:Name="listBox" HorizontalAlignment="Left" Height="104" Margin="126,186,0,0" VerticalAlignment="Top" Width="110" SelectionChanged="listBox_SelectionChanged" Grid.Column="2"/>
        <Button x:Name="button" Content="オフセットの検索" FontSize="12" HorizontalAlignment="Left" Margin="20,336,0,0" VerticalAlignment="Top" Width="80" Click="searchOffset_Click" Grid.Column="1" Height="20"/>
        <Button x:Name="button3" Content="オフセットの検索" FontSize="12" HorizontalAlignment="Left" Margin="251,336,0,0" VerticalAlignment="Top" Width="80" Click="searchOffset2_Click" Grid.Column="2" Height="20"/>
        <Button x:Name="loadFirstMessage" Content="文頭から表示" FontSize="12" HorizontalAlignment="Left" Margin="131,141,0,0" VerticalAlignment="Top" Width="100" Height="20" Click="loadFirstMessage_Click" Grid.Column="2"/>
        <Menu Grid.Column="2" Margin="371,10,30,399">
            <MenuItem Header="定型文挿入(_S)" FontSize="12" Click="MenuItem_Click">
                <MenuItem Header="{Binding s1}" Command="{Binding local:MyCommands.shortcutF1}" InputGestureText="F1" Click="MenuItem_Click_1"/>
                <MenuItem Header="{Binding s2}" Command="{Binding local:MyCommands.shortcutF2}" InputGestureText="F2" Click="MenuItem_Click_2"/>
                <MenuItem Header="{Binding s3}" Command="{Binding local:MyCommands.shortcutF3}" InputGestureText="F3" Click="MenuItem_Click_3"/>
                <MenuItem Header="{Binding s4}" Command="{Binding local:MyCommands.shortcutF4}" InputGestureText="F4" Click="MenuItem_Click_4"/>
                <MenuItem Header="{Binding s5}" Command="{Binding local:MyCommands.shortcutF5}" InputGestureText="F5" Click="MenuItem_Click_5"/>
                <MenuItem Header="{Binding s6}" Command="{Binding local:MyCommands.shortcutF6}" InputGestureText="F6" Click="MenuItem_Click_6"/>
                <MenuItem Header="{Binding s7}" Command="{Binding local:MyCommands.shortcutF7}" InputGestureText="F7" Click="MenuItem_Click_7"/>
                <MenuItem Header="{Binding s8}" Command="{Binding local:MyCommands.shortcutF8}" InputGestureText="F8" Click="MenuItem_Click_8"/>
                <MenuItem Header="{Binding s9}" Command="{Binding local:MyCommands.shortcutF9}" InputGestureText="F9" Click="MenuItem_Click_9"/>
                <MenuItem Header="{Binding s10}" Command="{Binding local:MyCommands.shortcutF10}" InputGestureText="F10" Click="MenuItem_Click_10"/>
                <MenuItem Header="{Binding s11}" Command="{Binding local:MyCommands.shortcutF11}" InputGestureText="F11" Click="MenuItem_Click_11"/>
                <MenuItem Header="{Binding s12}" Command="{Binding local:MyCommands.shortcutF12}" InputGestureText="F12" Click="MenuItem_Click_12"/>
            </MenuItem>
        </Menu>
        <Button Grid.Column="1" Content="ROMの再読込" HorizontalAlignment="Left" Margin="92,10,0,0" VerticalAlignment="Top" Click="Button_Click" Grid.ColumnSpan="2"/>
        <Button HorizontalAlignment="Left" VerticalAlignment="Top" Width="127" Grid.Column="2" Height="35" x:Name="clipboard_copy" Content="16進数を.byte形式にして&#xA;クリップボードにコピー" Click="clipboard_copy_Click" RenderTransformOrigin="0.627,0.3" Margin="344,365,0,0"/>
    </Grid>
</Window>
